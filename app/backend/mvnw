# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
#
# Required ENV vars:
# ------------------
#   JAVA_HOME - location of a JDK home dir
#
# Optional ENV vars
# -----------------
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
#     e.g. to debug Maven itself, use
#       set MAVEN_OPTS=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000
#   MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_SKIP_RC" ] ; then

  if [ -f /usr/local/etc/mavenrc ] ; then
    . /usr/local/etc/mavenrc
  fi

  if [ -f /etc/mavenrc ] ; then
    . /etc/mavenrc
  fi

  if [ -f "$HOME/.mavenrc" ] ; then
    . "$HOME/.mavenrc"
  fi

fi

# OS specific support.  $var _must_ be set to either true or false.
cygwin=false;
darwin=false;
mingw=false
case "`uname`" in
  CYGWIN*) cygwin=true ;;
  MINGW*) mingw=true;;
  Darwin*) darwin=true
    # Use /usr/libexec/java_home if available, otherwise fall through
    # We use stderr here so we don't mess with stdout
    if [ -z "$JAVA_HOME" ]; then
      if [ -x "/usr/libexec/java_home" ]; then
        JAVA_HOME="`/usr/libexec/java_home`"; export JAVA_HOME
      fi
    fi
    ;;
esac

if [ -z "$JAVA_HOME" ] ; then
  if [ -r /etc/gentoo-release ] ; then
    JAVA_HOME=`java-config --jre-home`
  fi
fi

# For Cygwin, ensure paths are in UNIX format before anything is touched
if $cygwin ; then
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME=`cygpath --unix "$JAVA_HOME"`
  [ -n "$CLASSPATH" ] &&
    CLASSPATH=`cygpath --path --unix "$CLASSPATH"`
fi

# For Mingw, ensure paths are in UNIX format before anything is touched
if $mingw ; then
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME="`(cd "$JAVA_HOME"; pwd)`"
fi

if [ -z "$JAVA_HOME" ]; then
  javaExecutable="`which javaw`"
  if [ -n "$javaExecutable" ] && ! [ "`expr \"$javaExecutable\" : '\([^ ]*\)'`" = "no" ]; then
    # readlink(1) is not available as standard on Solaris 10.
    readLink=`which readlink`
    if [ ! `expr "$readLink" : '\([^ ]*\)'` = "no" ]; then
      if $darwin ; then
        javaHome="`dirname \"$javaExecutable\"`"
        javaExecutable="`cd \"$javaHome\" && pwd -P`/javaw"
      else
        javaExecutable="`readlink -f \"$javaExecutable\"`"
      fi
      javaHome="`dirname \"$javaExecutable\"`"
      javaHome=`expr "$javaHome" : '\(.*\)/bin'`
      JAVA_HOME="$javaHome"
      export JAVA_HOME
    fi
  fi
fi

if [ -z "$JAVACMD" ] ; then
  if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
      # IBM's JDK on AIX uses strange locations for the executables
      JAVACMD="$JAVA_HOME/jre/sh/java"
    else
      JAVACMD="$JAVA_HOME/bin/java"
    fi
  else
    JAVACMD="`\\unset -f command; \\command -v java`"
  fi
fi

if [ ! -x "$JAVACMD" ] ; then
  echo "Error: JAVA_HOME is not defined correctly." >&2
  echo "  We cannot execute $JAVACMD" >&2
  exit 1
fi

if [ -z "$JAVA_HOME" ] ; then
  echo "Warning: JAVA_HOME environment variable is not set."
fi

# traverses directory structure from process work directory to filesystem root,
# repeating the directory name 'wrapperDir' in each sub-directory
findDir() {
  # while pass; find dir
  while true; do
    DIR=`pwd`
    if [ -d "$DIR/$1" ]; then
      # found dir
      echo "$DIR/$1"
      break
    fi
    if [ "$DIR" = "/" ]; then
      # at root; not found
      break
    fi
    cd ..
  done
}

# Absolute path, handling symlinks
SCRIPT="`readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0"`"
SCRIPT_DIR="`dirname "$SCRIPT"`"

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-}"
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR="`findDir ".mvn" "$SCRIPT_DIR"`"
  if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
    MAVEN_PROJECTBASEDIR="$SCRIPT_DIR"
  fi
fi
export MAVEN_PROJECTBASEDIR

MAVEN_OPTS="$(cat "$MAVEN_PROJECTBASEDIR/.mvn/jvm.config" 2>/dev/null) $MAVEN_OPTS"

# Provide a "tmp" directory underneath $MAVEN_PROJECTBASEDIR to place the wrapper jar
# to avoid permission issues when running mvn on a read-only filesystem (e.g. Docker volumes)
MAVEN_WRAPPER_TMP_DIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"

WRAPPER_JAR="$MAVEN_WRAPPER_TMP_DIR/maven-wrapper.jar"
WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

# If there is no wrapper jar, try to fetch it
if [ -r "$WRAPPER_JAR" ]; then
    echo "Found $WRAPPER_JAR"
else
    if ! command -v curl > /dev/null && ! command -v wget > /dev/null; then
        echo "Falling back to using Java to download the Maven wrapper..."
        DOWNLOAD_URL=$(grep -E '^wrapperUrl=' "$MAVEN_WRAPPER_TMP_DIR/maven-wrapper.properties" 2>/dev/null | sed 's/.*=//')
        if [ -n "$DOWNLOAD_URL" ]; then
            "$JAVACMD" \
              -classpath "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/dontexist.jar" \
              "$WRAPPER_LAUNCHER" "$@"
            exit $?
        fi
    fi
    if command -v curl > /dev/null; then
        curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_LAUNCHER_URL" 2>/dev/null || true
    elif command -v wget > /dev/null; then
        wget -q -O "$WRAPPER_JAR" "$WRAPPER_LAUNCHER_URL" 2>/dev/null || true
    fi
fi

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
fi

# Start the Maven wrapper
exec "$JAVACMD" \
  $MAVEN_OPTS \
  $MAVEN_DEBUG_OPTS \
  -classpath "$MAVEN_WRAPPER_TMP_DIR/maven-wrapper.jar" \
  "-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR}" \
  ${WRAPPER_LAUNCHER} "$@"
